# ───────── Database ─────────
DATABASE_URL="file:./local.db"
DATABASE_AUTH_TOKEN=""

# ───────── Auth.js ─────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# GitHub OAuth app: https://github.com/settings/developers
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Google OAuth (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ───────── Web Push ─────────
# Generate with: npm run vapid:gen
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:hello@example.com"

# ───────── Cron ─────────
# Generate with: openssl rand -base64 32
CRON_SECRET=""

# ───────── Sentry (optional) ─────────
SENTRY_DSN=""
PUBLIC_SENTRY_DSN=""

# ───────── Public (must be PUBLIC_ prefix for the client) ─────────
PUBLIC_VAPID_KEY="${VAPID_PUBLIC_KEY}"
PUBLIC_APP_URL="http://localhost:5173"
